# Variables de entorno para el proyecto de Agentes LangGraph

# ==============================================================================
# API KEYS DE PROVIDERS
# ==============================================================================

# OpenAI (para modelos GPT)
OPENAI_API_KEY=sk-...

# DeepSeek (para modelos deepseek-chat, deepseek-coder)
DEEPSEEK_API_KEY=sk-...

# OpenRouter (para modelos ligeros y de seguridad)
OPENROUTER_API_KEY=sk-...

# ==============================================================================
# API KEY DE SERVICIO EXTERNO
# ==============================================================================

# OpenWeatherMap (para agente meteorológico)
OPENWEATHER_API_KEY=tu_api_key_aqui

# ==============================================================================
# CONFIGURACIÓN DE PROVEEDORES LLM
# ==============================================================================

# Proveedor actual por defecto
CURRENT_LLM_PROVIDER=deepseek

# Modo de operación del orquestador
# - strict: solo usa herramientas reales, no improvisa
# - flexible: permite respuesta conversacional adicional
ORCHESTRATOR_MODE=strict