flowchart TD
    A[Usuario envía mensaje] --> B[Agente Orquestador]
    
    subgraph "Análisis de Intención"
        B --> C{¿LLM disponible?}
        C -->|Sí (DeepSeek)| D[Construir prompt con historial y herramientas]
        C -->|No| E[Análisis con reglas de palabras clave]
        D --> F[Enviar a DeepSeek]
        F --> G[Recibir JSON con intención]
        E --> G
    end
    
    G --> H[Validar decisión con DecisionValidator]
    
    H --> I{¿Herramienta válida?}
    I -->|Sí| J[Obtener herramienta del registro]
    I -->|No| K[Responder con chat genérico]
    
    J --> L{Tipo de herramienta}
    L -->|weather| M[Weather Agent]
    L -->|mcp| N[MCP Server]
    L -->|chat| O[Chat LLM (OpenRouter)]
    
    M --> P[Consultar OpenWeatherMap API]
    N --> Q[Executar herramienta MCP]
    O --> R[Generar respuesta conversacional]
    
    P --> S{¿Resultado exitoso?}
    Q --> S
    R --> S
    
    S -->|No| T[Generar error controlado]
    S -->|Sí| U[Formatear respuesta]
    
    T --> V[Validar seguridad con Guard Agent]
    U --> V
    
    V --> W[Persistir en memoria FAISS]
    W --> X[Enviar respuesta al usuario]