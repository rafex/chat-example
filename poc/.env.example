# ==========================================
# CONFIGURACIÓN DE ENTORNO
# ==========================================
# Copia este archivo a .env y reemplaza los valores con tus credenciales reales

# --- API Key de OpenWeatherMap ---
# Obtén tu clave en: https://openweathermap.org/api
OPENWEATHER_API_KEY=tu_api_key_aqui
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ==========================================
# CONFIGURACIÓN DE PROVEEDORES LLM
# ==========================================
# Puedes cambiar entre proveedores usando el comando: /model [openai|deepseek|openrouter]

# 1. OPENAI
# Web: https://platform.openai.com/
OPENAI_API_KEY=sk-proj-tu_clave_openai_aqui
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 2. DEEPSEEK
# Web: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-8ae8909fb0ad4fd8ab26852e059e5f24
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 3. OPENROUTER
# Web: https://openrouter.ai/
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Proveedor LLM actual por defecto (openai, deepseek, openrouter)
CURRENT_LLM_PROVIDER=openrouter

# ==========================================
# CONFIGURACIÓN DEL ORQUESTADOR
# ==========================================

# Modo de operación del orquestador:
# - strict: Solo usa herramientas reales, no inventa capacidades, respuesta controlada
#           Ideal para validar el comportamiento del orquestador en producción.
# - flexible: Permite respuesta conversacional adicional, útil para pruebas exploratorias.
#             Aun así no inventa herramientas inexistentes.
ORCHESTRATOR_MODE=strict

# Habilitar modo debug para logs detallados
ORCHESTRATOR_DEBUG=false
