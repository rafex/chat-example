# ==========================================
# CONFIGURACIÓN DE ENTORNO
# ==========================================
# Copia este archivo a .env y reemplaza los valores con tus credenciales reales.
# NOTA: La configuración de URLs, modelos y providers debe ir en poc/config.toml

# ==========================================
# API KEYS (Solo claves de API aquí)
# ==========================================

# --- API Key de OpenWeatherMap ---
# Obtén tu clave en: https://openweathermap.org/api
OPENWEATHER_API_KEY=tu_api_key_aqui

# ==========================================
# API KEYS DE PROVIDERS LLM
# ==========================================

# 1. OPENAI
# Web: https://platform.openai.com/
OPENAI_API_KEY=sk-proj-tu_clave_openai_aqui

# 2. DEEPSEEK
# Web: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-tu_clave_deepseek_aqui

# 3. OPENROUTER
# Web: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-tu_clave_openrouter_aqui

# ==========================================
# CONFIGURACIÓN DE ENTORNO (Opcional)
# ==========================================

# Modo de operación del orquestador (sobrescribe config.toml si está definido):
# - strict: Solo usa herramientas reales, no inventa capacidades
# - flexible: Permite respuesta conversacional adicional
# ORCHESTRATOR_MODE=strict

# Habilitar modo debug para logs detallados (sobrescribe config.toml)
# ORCHESTRATOR_DEBUG=false
