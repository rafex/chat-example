# Configuración de variables de entorno para el Agente Meteorológico
# Copia este archivo a .env y reemplaza los valores con tus credenciales reales

# API Key de OpenWeatherMap (obtenla en https://openweathermap.org/api)
OPENWEATHER_API_KEY=tu_api_key_aqui

# Configuración opcional de la API
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# API Key de DeepSeek (obtenla en https://platform.deepseek.com/)
# DeepSeek es un LLM open source que usaremos para generar recomendaciones naturales
DEEPSEEK_API_KEY=tu_api_key_deepseek_aqui

# URL de la API de DeepSeek (compatible con formato OpenAI)
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Modelo a usar (puedes cambiarlo según disponibilidad)
DEEPSEEK_MODEL=deepseek-chat
