# Configuración de variables de entorno para el Agente Meteorológico
# Copia este archivo a .env y reemplaza los valores con tus credenciales reales

# API Key de OpenWeatherMap (obtenla en https://openweathermap.org/api)
OPENWEATHER_API_KEY=tu_api_key_aqui

# Configuración opcional de la API
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# Proveedor LLM Genérico (compatible con OpenAI)
# Soporta: DeepSeek, OpenAI, y cualquier proveedor con API compatible con OpenAI
# 
# DeepSeek: https://platform.deepseek.com/
# OpenAI: https://platform.openai.com/
# Otros: Cualquier proveedor con API OpenAI-compatible

LLM_PROVIDER_API_KEY=sk-8ae8909fb0ad4fd8ab26852e059e5f24
LLM_PROVIDER_API_BASE=https://api.deepseek.com/v1
LLM_PROVIDER_MODEL=deepseek-chat
